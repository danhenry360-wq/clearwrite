---
const tones = [
  { id: 'neutral', label: 'Neutral' },
  { id: 'professional', label: 'Professional' },
  { id: 'formal', label: 'Formal' },
  { id: 'friendly', label: 'Friendly' },
  { id: 'casual', label: 'Casual' },
  { id: 'confident', label: 'Confident' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ClearWrite</title>
    <meta name="description" content="Turn rough notes into clean, correct English. Choose UK or US and the tone that fits." />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect x='2' y='2' width='28' height='28' rx='9' fill='%231c1b19'/><path d='M8.5 13 q2.1 -2.8 4.2 0 t4.2 0 t4.2 0' fill='none' stroke='%23f4f2ec' stroke-width='2' stroke-linecap='round' opacity='0.7'/><path d='M8.5 20.5 H23' fill='none' stroke='%233f8e6f' stroke-width='2.4' stroke-linecap='round'/></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap" rel="stylesheet" />
    <script is:inline>
      (function () {
        var pref = localStorage.getItem('clearwrite.theme') || 'system';
        var dark = pref === 'dark' || (pref === 'system' && matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        document.documentElement.dataset.themePref = pref;
      })();
    </script>
  </head>
  <body>
    <header class="site">
      <a class="brand" href="/" aria-label="ClearWrite home">
        <svg class="mark" viewBox="0 0 32 32" aria-hidden="true">
          <rect x="2" y="2" width="28" height="28" rx="9" class="mark-bg"/>
          <path class="mark-wave" d="M8.5 13 q2.1 -2.8 4.2 0 t4.2 0 t4.2 0"/>
          <path class="mark-line" d="M8.5 20.5 H23"/>
        </svg>
        <span class="brand-name">ClearWrite</span>
      </a>
      <div class="theme" id="theme" role="group" aria-label="Theme">
        <button type="button" class="theme-btn" data-theme-val="light" aria-label="Light" title="Light">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19"/></svg>
        </button>
        <button type="button" class="theme-btn" data-theme-val="system" aria-label="System" title="System">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </button>
        <button type="button" class="theme-btn" data-theme-val="dark" aria-label="Dark" title="Dark">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        </button>
      </div>
    </header>

    <main class="wrap">
      <section class="intro">
        <h1>Say exactly what you mean.</h1>
        <p>Paste rough text. Get it back clear, correct and natural — in the language and tone you choose.</p>
      </section>

      <section class="bar">
        <div class="field">
          <span class="field-label">Language</span>
          <div class="seg" id="dialect" role="group" aria-label="Target language">
            <button type="button" class="seg-btn active" data-val="US">US English</button>
            <button type="button" class="seg-btn" data-val="UK">UK English</button>
            <button type="button" class="seg-btn" data-val="FR">Français</button>
          </div>
        </div>
        <div class="field" id="tone-field">
          <span class="field-label">Tone</span>
          <div class="pills" id="tone" role="group" aria-label="Tone">
            {tones.map((t, i) => (
              <button type="button" class:list={["pill", i === 0 && "active"]} data-val={t.id}>{t.label}</button>
            ))}
          </div>
        </div>
        <div class="field">
          <span class="field-label">Mode</span>
          <div class="pills" id="mode" role="group" aria-label="Mode">
            <button type="button" class="pill active" data-val="polish">Polish</button>
            <button type="button" class="pill" data-val="prompt">Prompt-ready</button>
          </div>
        </div>
      </section>

      <section class="editor">
        <div class="pane">
          <div class="pane-top">
            <span class="pane-title">Draft</span>
            <span class="count" id="count">0 / 12,000 characters</span>
          </div>
          <textarea id="input" spellcheck="false" placeholder="Enter or paste your text here. Raw thoughts welcome — don't worry about mistakes."></textarea>
          <button class="mic" id="mic" type="button" hidden aria-label="Dictate with your voice" title="Dictate">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="3" width="6" height="11" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/></svg>
            <span class="mic-pulse"></span>
          </button>
        </div>

        <div class="pane out">
          <div class="pane-top">
            <span class="pane-title">Clean</span>
            <div class="pane-tools">
              <button class="tool-btn" id="diff" type="button" hidden aria-pressed="false" title="Show what changed">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M5 8l-3 4 3 4M19 8l3 4-3 4"/></svg>
                <span>Changes</span>
              </button>
              <button class="tool-btn icon" id="copy" type="button" hidden aria-label="Copy to clipboard" title="Copy to clipboard">
                <svg class="i-copy" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2.5"/><path d="M5 15V5a2 2 0 0 1 2-2h8"/></svg>
                <svg class="i-check" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" hidden><path d="M5 12.5l4 4 10-10"/></svg>
              </button>
            </div>
          </div>
          <div id="output" class="output" aria-live="polite">
            <p class="ghost-text">Your refined text appears here.</p>
          </div>
        </div>
      </section>

      <div class="actions">
        <button class="reset" id="clear" type="button">Clear</button>
        <button class="run" id="go" type="button">
          <span class="run-text">Refine</span>
          <span class="dots" hidden><i></i><i></i><i></i></span>
        </button>
      </div>

      <section class="recent" id="recent-wrap" hidden>
        <div class="recent-head">
          <h2>Recent</h2>
          <button class="link-btn subtle" id="clear-history" type="button">Clear</button>
        </div>
        <div id="history" class="history"></div>
      </section>
    </main>

    <footer class="foot">
      <span>ClearWrite</span>
      <span class="sep">·</span>
      <span>Your history stays on this device</span>
    </footer>

    <script>
      const $ = (s) => document.querySelector(s);
      const input = $('#input');
      const output = $('#output');
      const go = $('#go');
      const copyBtn = $('#copy');
      const diffBtn = $('#diff');
      const toneField = $('#tone-field');
      const count = $('#count');
      const historyEl = $('#history');
      const recentWrap = $('#recent-wrap');
      const clearHistoryBtn = $('#clear-history');
      const KEY = 'clearwrite.history';
      let dialect = 'US';
      let tone = 'neutral';
      let mode = 'polish';
      // last refine, for the Copy button and the Changes (diff) view
      let lastInput = '';
      let lastResult = '';
      let diffOn = false;

      // theme: light / dark / system
      const root = document.documentElement;
      const mq = matchMedia('(prefers-color-scheme: dark)');
      function applyTheme(pref) {
        localStorage.setItem('clearwrite.theme', pref);
        root.dataset.themePref = pref;
        const dark = pref === 'dark' || (pref === 'system' && mq.matches);
        root.dataset.theme = dark ? 'dark' : 'light';
        document.querySelectorAll('#theme .theme-btn').forEach((b) =>
          b.classList.toggle('active', b.dataset.themeVal === pref));
      }
      document.querySelectorAll('#theme .theme-btn').forEach((b) => {
        b.addEventListener('click', () => applyTheme(b.dataset.themeVal));
      });
      mq.addEventListener('change', () => {
        if ((root.dataset.themePref || 'system') === 'system') applyTheme('system');
      });
      applyTheme(localStorage.getItem('clearwrite.theme') || 'system');

      document.querySelectorAll('#dialect .seg-btn').forEach((b) => {
        b.addEventListener('click', () => {
          document.querySelectorAll('#dialect .seg-btn').forEach((x) => x.classList.remove('active'));
          b.classList.add('active');
          dialect = b.dataset.val;
        });
      });
      document.querySelectorAll('#tone .pill').forEach((b) => {
        b.addEventListener('click', () => {
          document.querySelectorAll('#tone .pill').forEach((x) => x.classList.remove('active'));
          b.classList.add('active');
          tone = b.dataset.val;
        });
      });
      document.querySelectorAll('#mode .pill').forEach((b) => {
        b.addEventListener('click', () => applyMode(b.dataset.val));
      });
      // In Prompt-ready mode, tone is not meaningful — dim that control.
      function applyMode(val) {
        mode = val === 'prompt' ? 'prompt' : 'polish';
        document.querySelectorAll('#mode .pill').forEach((x) => x.classList.toggle('active', x.dataset.val === mode));
        toneField.classList.toggle('disabled', mode === 'prompt');
      }

      const MAX = 12000;
      function setCount(n) {
        count.textContent = n.toLocaleString() + ' / 12,000 characters';
        count.classList.toggle('over', n > MAX);
      }
      input.addEventListener('input', () => setCount(input.value.length));
      $('#clear').addEventListener('click', () => { input.value = ''; setCount(0); input.focus(); });

      // voice dictation (Web Speech API) — only if the browser supports it
      const micBtn = $('#mic');
      const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (SR) {
        micBtn.hidden = false;
        const recog = new SR();
        recog.continuous = true;
        recog.interimResults = true;
        let listening = false;
        let finalText = '';

        function startDictation() {
          finalText = input.value ? input.value.trim() + ' ' : '';
          recog.lang = { US: 'en-US', UK: 'en-GB', FR: 'fr-FR' }[dialect] || 'en-US';
          try { recog.start(); } catch (e) {}
          listening = true;
          micBtn.classList.add('listening');
          micBtn.setAttribute('aria-label', 'Stop dictation');
        }
        function stopDictation() {
          listening = false;
          micBtn.classList.remove('listening');
          micBtn.setAttribute('aria-label', 'Dictate with your voice');
          try { recog.stop(); } catch (e) {}
        }
        recog.onresult = (e) => {
          let interim = '';
          for (let i = e.resultIndex; i < e.results.length; i++) {
            const r = e.results[i];
            if (r.isFinal) finalText += r[0].transcript + ' ';
            else interim += r[0].transcript;
          }
          input.value = (finalText + interim).replace(/\s+/g, ' ').trimStart();
          setCount(input.value.length);
        };
        recog.onend = () => { if (listening) { try { recog.start(); } catch (e) {} } };
        recog.onerror = (e) => { if (e.error === 'not-allowed' || e.error === 'service-not-allowed') stopDictation(); };
        micBtn.addEventListener('click', () => (listening ? stopDictation() : startDictation()));
      }

      function setBusy(on) {
        go.disabled = on;
        go.classList.toggle('busy', on);
        go.querySelector('.run-text').textContent = on ? 'Refining' : 'Refine';
        go.querySelector('.dots').hidden = !on;
      }

      const escapeHtml = (s) =>
        s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

      // Word-level diff (LCS) so users can see exactly what was changed.
      function diffWords(aStr, bStr) {
        const a = aStr.trim().split(/\s+/).filter(Boolean);
        const b = bStr.trim().split(/\s+/).filter(Boolean);
        const n = a.length, m = b.length;
        const dp = Array.from({ length: n + 1 }, () => new Int32Array(m + 1));
        for (let i = n - 1; i >= 0; i--)
          for (let j = m - 1; j >= 0; j--)
            dp[i][j] = a[i] === b[j] ? dp[i + 1][j + 1] + 1 : Math.max(dp[i + 1][j], dp[i][j + 1]);
        const out = [];
        let i = 0, j = 0;
        while (i < n && j < m) {
          if (a[i] === b[j]) { out.push(['eq', b[j]]); i++; j++; }
          else if (dp[i + 1][j] >= dp[i][j + 1]) { out.push(['del', a[i]]); i++; }
          else { out.push(['add', b[j]]); j++; }
        }
        while (i < n) out.push(['del', a[i++]]);
        while (j < m) out.push(['add', b[j++]]);
        return out;
      }

      function renderDiffHtml(srcInput, result) {
        return diffWords(srcInput, result)
          .map(([t, w]) =>
            t === 'eq' ? escapeHtml(w)
            : t === 'add' ? '<ins>' + escapeHtml(w) + '</ins>'
            : '<del>' + escapeHtml(w) + '</del>')
          .join(' ');
      }

      function renderOutput() {
        output.innerHTML = '';
        const p = document.createElement('p');
        p.className = 'result';
        if (diffOn && lastInput) p.innerHTML = renderDiffHtml(lastInput, lastResult);
        else p.textContent = lastResult;
        output.appendChild(p);
      }

      function showOutput(result, srcInput) {
        lastResult = result;
        lastInput = srcInput != null ? srcInput : '';
        diffOn = false;
        diffBtn.setAttribute('aria-pressed', 'false');
        renderOutput();
        copyBtn.hidden = false;
        // Diff only makes sense for line edits, not the restructured prompt mode.
        diffBtn.hidden = mode === 'prompt' || !lastInput;
      }

      diffBtn.addEventListener('click', () => {
        diffOn = !diffOn;
        diffBtn.classList.toggle('on', diffOn);
        diffBtn.setAttribute('aria-pressed', String(diffOn));
        renderOutput();
      });

      async function refine() {
        const text = input.value.trim();
        if (!text) { input.focus(); return; }
        setBusy(true);
        copyBtn.hidden = true;
        diffBtn.hidden = true;
        try {
          const res = await fetch('/api/rewrite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text, dialect, tone, mode }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Something went wrong.');
          showOutput(data.result, text);
          saveHistory({ input: text, output: data.result, dialect, tone, mode, ts: Date.now() });
        } catch (e) {
          output.innerHTML = '<p class="err">' + (e.message || 'Failed. Please try again.') + '</p>';
        } finally {
          setBusy(false);
        }
      }

      go.addEventListener('click', refine);
      input.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') refine();
      });

      const iCopy = copyBtn.querySelector('.i-copy');
      const iCheck = copyBtn.querySelector('.i-check');
      copyBtn.addEventListener('click', async () => {
        if (!lastResult) return;
        try { await navigator.clipboard.writeText(lastResult); } catch { return; }
        iCopy.hidden = true; iCheck.hidden = false;
        copyBtn.classList.add('done');
        setTimeout(() => { iCopy.hidden = false; iCheck.hidden = true; copyBtn.classList.remove('done'); }, 1400);
      });

      function loadHistory() { try { return JSON.parse(localStorage.getItem(KEY)) || []; } catch { return []; } }
      function saveHistory(item) {
        const list = loadHistory();
        list.unshift(item);
        localStorage.setItem(KEY, JSON.stringify(list.slice(0, 50)));
        renderHistory();
      }
      function applyTone(val) {
        tone = val;
        document.querySelectorAll('#tone .pill').forEach((x) => x.classList.toggle('active', x.dataset.val === val));
      }
      function applyDialect(val) {
        dialect = val;
        document.querySelectorAll('#dialect .seg-btn').forEach((x) => x.classList.toggle('active', x.dataset.val === val));
      }
      function renderHistory() {
        const list = loadHistory();
        recentWrap.hidden = list.length === 0;
        historyEl.innerHTML = '';
        list.forEach((it) => {
          const card = document.createElement('button');
          card.className = 'rec';
          card.type = 'button';
          const tag = document.createElement('div');
          tag.className = 'rec-tags';
          tag.innerHTML = '<span class="tag">' + it.dialect + '</span><span class="tag soft">' +
            it.tone + '</span><span class="rec-time">' + new Date(it.ts).toLocaleDateString(undefined,{month:'short',day:'numeric'}) + '</span>';
          const body = document.createElement('div');
          body.className = 'rec-body';
          body.textContent = it.output;
          card.append(tag, body);
          card.addEventListener('click', () => {
            input.value = it.input;
            setCount(it.input.length);
            applyDialect(it.dialect);
            applyTone(it.tone);
            applyMode(it.mode || 'polish');
            showOutput(it.output, it.input);
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
          historyEl.appendChild(card);
        });
      }
      clearHistoryBtn.addEventListener('click', () => {
        if (confirm('Clear all recent items?')) { localStorage.removeItem(KEY); renderHistory(); }
      });
      renderHistory();
    </script>

    <style is:global>
      :root {
        --bg: #f4f2ec;
        --surface: #fffefb;
        --ink: #1c1b19;
        --muted: #807b72;
        --faint: #a8a299;
        --line: #e4e0d6;
        --line-2: #cdc7ba;
        --text-2: #524e47;
        --accent: #2f6b54;
        --accent-soft: #e7efe9;
        --on-accent: #fffefb;
        --danger: #b1442f;
        --shadow: 0 1px 2px rgba(28,27,25,.04), 0 8px 24px rgba(28,27,25,.05);
      }
      html[data-theme="dark"] {
        --bg: #181715;
        --surface: #211f1c;
        --ink: #ece8df;
        --muted: #9b958a;
        --faint: #6c675e;
        --line: #2c2925;
        --line-2: #46413a;
        --text-2: #c4beb3;
        --accent: #6dbb98;
        --accent-soft: #233029;
        --on-accent: #181715;
        --danger: #e08568;
        --shadow: 0 1px 2px rgba(0,0,0,.2), 0 10px 28px rgba(0,0,0,.28);
      }
      html, body { background: var(--bg); }
      body, .site, .wrap, .pane, .seg, .pill, .rec, .run, .foot, textarea, .result, .ghost-text,
      .field-label, .pane-title, .count, .rec-time, .intro p, .intro h1, .wordmark {
        transition: background-color .25s ease, color .25s ease, border-color .25s ease;
      }
      * { box-sizing: border-box; }
      [hidden] { display: none !important; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: 'Inter', system-ui, sans-serif;
        background: var(--bg);
        color: var(--ink);
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        line-height: 1.5;
      }

      .site {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.5rem clamp(1.2rem, 5vw, 3rem);
        max-width: 1080px; margin: 0 auto;
      }
      .brand { display: inline-flex; align-items: center; gap: .55rem; text-decoration: none; }
      .mark { width: 30px; height: 30px; display: block; flex: none; }
      .mark-bg { fill: var(--ink); }
      .mark-wave { fill: none; stroke: var(--surface); stroke-width: 2; stroke-linecap: round; opacity: .65; }
      .mark-line { fill: none; stroke: var(--accent); stroke-width: 2.4; stroke-linecap: round; }
      .brand-name {
        font-family: 'Newsreader', Georgia, serif;
        font-size: 1.4rem; font-weight: 600; letter-spacing: -.01em; color: var(--ink);
      }
      .theme { display: inline-flex; background: var(--surface); border: 1px solid var(--line-2); border-radius: 9px; padding: 3px; box-shadow: var(--shadow); }
      .theme-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 28px; border: 0; background: transparent; color: var(--faint);
        cursor: pointer; border-radius: 6px; transition: color .15s, background .15s;
      }
      .theme-btn:hover { color: var(--muted); }
      .theme-btn.active { background: var(--ink); color: var(--surface); }

      .wrap { max-width: 1080px; margin: 0 auto; padding: clamp(1.2rem, 5vw, 2rem) clamp(1.2rem, 5vw, 3rem) 4rem; }

      .intro { max-width: 620px; margin: clamp(1rem, 4vw, 2.5rem) 0 2.2rem; }
      .intro h1 {
        font-family: 'Newsreader', Georgia, serif;
        font-weight: 500; font-size: clamp(2rem, 5vw, 2.9rem);
        line-height: 1.1; letter-spacing: -.02em; margin: 0 0 .6rem;
      }
      .intro p { margin: 0; color: var(--muted); font-size: 1.02rem; max-width: 30em; }

      .bar { display: flex; flex-wrap: wrap; gap: 1.6rem 2.4rem; margin-bottom: 1.4rem; }
      .field { display: flex; flex-direction: column; gap: .5rem; }
      .field-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .09em; color: var(--faint); font-weight: 500; }

      /* Language and Tone share one pill treatment for visual harmony. */
      .seg, .pills { display: flex; flex-wrap: wrap; gap: .4rem; }
      .seg-btn, .pill {
        border: 1px solid var(--line-2); background: var(--surface); color: var(--text-2);
        cursor: pointer; font: inherit; font-size: .86rem; font-weight: 500; padding: .42rem .9rem; border-radius: 999px;
        transition: all .15s;
      }
      .seg-btn:hover, .pill:hover { border-color: var(--muted); color: var(--ink); }
      .seg-btn.active, .pill.active { background: var(--accent-soft); border-color: var(--accent); color: var(--accent); }

      .field.disabled { opacity: .4; pointer-events: none; }

      .editor { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
      @media (max-width: 740px) { .editor { grid-template-columns: 1fr; } }

      .pane {
        position: relative;
        background: var(--surface); border: 1px solid var(--line); border-radius: 16px;
        display: flex; flex-direction: column; min-height: 340px; overflow: hidden; box-shadow: var(--shadow);
      }
      .pane-top {
        display: flex; align-items: center; justify-content: space-between;
        padding: .85rem 1.1rem; border-bottom: 1px solid var(--line);
      }
      .pane-title { font-size: .74rem; text-transform: uppercase; letter-spacing: .09em; color: var(--faint); font-weight: 500; }
      .count { font-size: .78rem; color: var(--text-2); font-weight: 500; font-variant-numeric: tabular-nums; }
      .count.over { color: var(--danger); font-weight: 500; }
      .mic {
        position: absolute; bottom: .9rem; right: .9rem; z-index: 2;
        display: inline-flex; align-items: center; justify-content: center;
        width: 40px; height: 40px; border-radius: 50%; cursor: pointer;
        border: 1px solid var(--line-2); background: var(--surface); color: var(--muted);
        box-shadow: var(--shadow);
        transition: color .15s, border-color .15s, background .15s, transform .12s;
      }
      .mic:hover { transform: translateY(-1px); }
      .mic:hover { color: var(--ink); border-color: var(--muted); }
      .mic.listening { color: #fff; background: var(--danger); border-color: var(--danger); }
      .mic-pulse { position: absolute; inset: -1px; border-radius: 50%; pointer-events: none; }
      .mic.listening .mic-pulse { animation: ring 1.4s ease-out infinite; box-shadow: 0 0 0 0 var(--danger); }
      @keyframes ring {
        0% { box-shadow: 0 0 0 0 rgba(177,68,47,.5); }
        100% { box-shadow: 0 0 0 9px rgba(177,68,47,0); }
      }

      textarea {
        flex: 1; resize: none; border: 0; background: transparent; color: var(--ink);
        padding: 1.2rem 1.2rem 3.6rem; font: inherit; font-size: 1.02rem; line-height: 1.7;
      }
      textarea::placeholder { color: var(--faint); }
      textarea:focus { outline: none; }

      .out { background: var(--surface); }
      .output { flex: 1; padding: 1.2rem; overflow-y: auto; }
      .result {
        margin: 0; font-family: 'Newsreader', Georgia, serif; font-size: 1.18rem;
        line-height: 1.65; color: var(--ink); white-space: pre-wrap;
      }
      .ghost-text { margin: 0; color: var(--faint); font-family: 'Newsreader', Georgia, serif; font-size: 1.18rem; font-style: italic; }
      .err { margin: 0; color: var(--danger); }

      .actions { display: flex; align-items: center; justify-content: flex-end; gap: .8rem; margin-top: 1.2rem; }
      .reset {
        background: transparent; border: 0; color: var(--muted); cursor: pointer;
        font: inherit; font-size: .9rem; padding: .55rem .6rem;
      }
      .reset:hover { color: var(--ink); }
      .run {
        display: inline-flex; align-items: center; gap: .55rem;
        background: var(--accent); color: var(--on-accent); border: 0; border-radius: 11px;
        padding: .7rem 1.7rem; cursor: pointer; font: inherit; font-size: .95rem; font-weight: 600;
        transition: transform .12s, opacity .12s, filter .12s; box-shadow: var(--shadow);
      }
      .run:hover { transform: translateY(-1px); filter: brightness(1.05); }
      .run:disabled { cursor: default; opacity: .85; transform: none; }
      .dots { display: inline-flex; gap: 3px; }
      .dots i { width: 4px; height: 4px; border-radius: 50%; background: currentColor; opacity: .4; animation: blink 1.2s infinite ease-in-out; }
      .dots i:nth-child(2) { animation-delay: .2s; }
      .dots i:nth-child(3) { animation-delay: .4s; }
      @keyframes blink { 0%, 80%, 100% { opacity: .25; } 40% { opacity: 1; } }

      .link-btn { background: transparent; border: 0; color: var(--accent); cursor: pointer; font: inherit; font-size: .82rem; font-weight: 500; padding: 0; }
      .link-btn:hover { text-decoration: underline; }
      .link-btn.subtle { color: var(--muted); }

      /* Clean-pane tools: Changes (diff) toggle + Copy icon */
      .pane-tools { display: inline-flex; align-items: center; gap: .25rem; }
      .tool-btn {
        display: inline-flex; align-items: center; gap: .3rem;
        background: transparent; border: 0; color: var(--muted); cursor: pointer;
        font: inherit; font-size: .76rem; font-weight: 500; padding: .28rem .5rem; border-radius: 7px;
        transition: color .15s, background .15s;
      }
      .tool-btn svg { display: block; }
      .tool-btn.icon { padding: .3rem; }
      .tool-btn:hover { color: var(--ink); background: var(--accent-soft); }
      .tool-btn.on { color: var(--accent); background: var(--accent-soft); }
      .tool-btn.done { color: var(--accent); }

      /* Diff highlighting in the Clean output */
      .result ins {
        text-decoration: none; background: var(--accent-soft); color: var(--accent);
        border-radius: 3px; padding: 0 .14em;
        -webkit-box-decoration-break: clone; box-decoration-break: clone;
      }
      .result del { text-decoration: line-through; color: var(--faint); }

      .recent { margin-top: 3rem; }
      .recent-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1rem; }
      .recent-head h2 { font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: 1.35rem; margin: 0; }
      .history { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: .9rem; }
      .rec {
        text-align: left; background: var(--surface); border: 1px solid var(--line); border-radius: 13px;
        padding: 1rem; cursor: pointer; font: inherit; color: var(--ink);
        transition: border-color .15s, transform .12s, box-shadow .15s;
      }
      .rec:hover { border-color: var(--line-2); transform: translateY(-2px); box-shadow: var(--shadow); }
      .rec-tags { display: flex; align-items: center; gap: .4rem; margin-bottom: .6rem; }
      .tag { font-size: .68rem; text-transform: uppercase; letter-spacing: .05em; background: var(--ink); color: var(--surface); border-radius: 5px; padding: .12rem .4rem; }
      .tag.soft { background: var(--accent-soft); color: var(--accent); }
      .rec-time { font-size: .72rem; color: var(--faint); margin-left: auto; }
      .rec-body {
        font-family: 'Newsreader', Georgia, serif; font-size: .98rem; line-height: 1.55; color: var(--muted);
        display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
      }

      .foot {
        display: flex; align-items: center; justify-content: center; gap: .6rem;
        color: var(--faint); font-size: .8rem;
        padding: 2.5rem 1rem calc(3.5rem + env(safe-area-inset-bottom, 0px));
        border-top: 1px solid var(--line); max-width: 1080px; margin: 2rem auto 0;
      }
      .foot .sep { opacity: .5; }
    </style>
  </body>
</html>
