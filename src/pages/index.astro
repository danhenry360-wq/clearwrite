---
const tones = [
  { id: 'neutral', label: 'Neutral' },
  { id: 'professional', label: 'Professional' },
  { id: 'formal', label: 'Formal' },
  { id: 'friendly', label: 'Friendly' },
  { id: 'casual', label: 'Casual' },
  { id: 'confident', label: 'Confident' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ClearWrite</title>
    <meta name="description" content="Turn rough notes into clean, correct English. Choose UK or US and the tone that fits." />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%231c1b19'/><text x='16' y='23' font-size='18' text-anchor='middle' font-family='Georgia,serif' fill='%23f7f6f3'>C</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site">
      <a class="wordmark" href="/">ClearWrite</a>
      <nav class="meta-nav">
        <span class="dot"></span>
        <span>UK &amp; US English</span>
      </nav>
    </header>

    <main class="wrap">
      <section class="intro">
        <h1>Say exactly what you mean.</h1>
        <p>Paste rough text below. Get it back clean, correct and natural — in the English and tone you choose.</p>
      </section>

      <section class="bar">
        <div class="field">
          <span class="field-label">English</span>
          <div class="seg" id="dialect" role="group" aria-label="English variant">
            <button type="button" class="seg-btn active" data-val="US">US</button>
            <button type="button" class="seg-btn" data-val="UK">UK</button>
          </div>
        </div>
        <div class="field">
          <span class="field-label">Tone</span>
          <div class="pills" id="tone" role="group" aria-label="Tone">
            {tones.map((t, i) => (
              <button type="button" class:list={["pill", i === 0 && "active"]} data-val={t.id}>{t.label}</button>
            ))}
          </div>
        </div>
      </section>

      <section class="editor">
        <div class="pane">
          <div class="pane-top">
            <span class="pane-title">Draft</span>
            <span class="count" id="count">0</span>
          </div>
          <textarea id="input" spellcheck="false" placeholder="Type or paste here. Don't worry about mistakes."></textarea>
        </div>

        <div class="pane out">
          <div class="pane-top">
            <span class="pane-title">Clean</span>
            <button class="link-btn" id="copy" type="button" hidden>Copy</button>
          </div>
          <div id="output" class="output" aria-live="polite">
            <p class="ghost-text">Your refined text appears here.</p>
          </div>
        </div>
      </section>

      <div class="actions">
        <button class="reset" id="clear" type="button">Clear</button>
        <button class="run" id="go" type="button">
          <span class="run-text">Refine</span>
          <span class="dots" hidden><i></i><i></i><i></i></span>
        </button>
      </div>

      <section class="recent" id="recent-wrap" hidden>
        <div class="recent-head">
          <h2>Recent</h2>
          <button class="link-btn subtle" id="clear-history" type="button">Clear</button>
        </div>
        <div id="history" class="history"></div>
      </section>
    </main>

    <footer class="foot">
      <span>ClearWrite</span>
      <span class="sep">·</span>
      <span>Your history stays on this device</span>
    </footer>

    <script>
      const $ = (s) => document.querySelector(s);
      const input = $('#input');
      const output = $('#output');
      const go = $('#go');
      const copyBtn = $('#copy');
      const count = $('#count');
      const historyEl = $('#history');
      const recentWrap = $('#recent-wrap');
      const clearHistoryBtn = $('#clear-history');
      const KEY = 'clearwrite.history';
      let dialect = 'US';
      let tone = 'neutral';

      document.querySelectorAll('#dialect .seg-btn').forEach((b) => {
        b.addEventListener('click', () => {
          document.querySelectorAll('#dialect .seg-btn').forEach((x) => x.classList.remove('active'));
          b.classList.add('active');
          dialect = b.dataset.val;
        });
      });
      document.querySelectorAll('#tone .pill').forEach((b) => {
        b.addEventListener('click', () => {
          document.querySelectorAll('#tone .pill').forEach((x) => x.classList.remove('active'));
          b.classList.add('active');
          tone = b.dataset.val;
        });
      });

      input.addEventListener('input', () => { count.textContent = input.value.length; });
      $('#clear').addEventListener('click', () => { input.value = ''; count.textContent = '0'; input.focus(); });

      function setBusy(on) {
        go.disabled = on;
        go.classList.toggle('busy', on);
        go.querySelector('.run-text').textContent = on ? 'Refining' : 'Refine';
        go.querySelector('.dots').hidden = !on;
      }

      function showOutput(textVal) {
        output.innerHTML = '';
        const p = document.createElement('p');
        p.className = 'result';
        p.textContent = textVal;
        output.appendChild(p);
        copyBtn.hidden = false;
      }

      async function refine() {
        const text = input.value.trim();
        if (!text) { input.focus(); return; }
        setBusy(true);
        copyBtn.hidden = true;
        try {
          const res = await fetch('/api/rewrite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text, dialect, tone }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Something went wrong.');
          showOutput(data.result);
          saveHistory({ input: text, output: data.result, dialect, tone, ts: Date.now() });
        } catch (e) {
          output.innerHTML = '<p class="err">' + (e.message || 'Failed. Please try again.') + '</p>';
        } finally {
          setBusy(false);
        }
      }

      go.addEventListener('click', refine);
      input.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') refine();
      });

      copyBtn.addEventListener('click', async () => {
        const t = output.querySelector('.result');
        if (!t) return;
        await navigator.clipboard.writeText(t.textContent);
        copyBtn.textContent = 'Copied';
        setTimeout(() => (copyBtn.textContent = 'Copy'), 1400);
      });

      function loadHistory() { try { return JSON.parse(localStorage.getItem(KEY)) || []; } catch { return []; } }
      function saveHistory(item) {
        const list = loadHistory();
        list.unshift(item);
        localStorage.setItem(KEY, JSON.stringify(list.slice(0, 50)));
        renderHistory();
      }
      function applyTone(val) {
        tone = val;
        document.querySelectorAll('#tone .pill').forEach((x) => x.classList.toggle('active', x.dataset.val === val));
      }
      function applyDialect(val) {
        dialect = val;
        document.querySelectorAll('#dialect .seg-btn').forEach((x) => x.classList.toggle('active', x.dataset.val === val));
      }
      function renderHistory() {
        const list = loadHistory();
        recentWrap.hidden = list.length === 0;
        historyEl.innerHTML = '';
        list.forEach((it) => {
          const card = document.createElement('button');
          card.className = 'rec';
          card.type = 'button';
          const tag = document.createElement('div');
          tag.className = 'rec-tags';
          tag.innerHTML = '<span class="tag">' + it.dialect + '</span><span class="tag soft">' +
            it.tone + '</span><span class="rec-time">' + new Date(it.ts).toLocaleDateString(undefined,{month:'short',day:'numeric'}) + '</span>';
          const body = document.createElement('div');
          body.className = 'rec-body';
          body.textContent = it.output;
          card.append(tag, body);
          card.addEventListener('click', () => {
            input.value = it.input;
            count.textContent = it.input.length;
            applyDialect(it.dialect);
            applyTone(it.tone);
            showOutput(it.output);
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
          historyEl.appendChild(card);
        });
      }
      clearHistoryBtn.addEventListener('click', () => {
        if (confirm('Clear all recent items?')) { localStorage.removeItem(KEY); renderHistory(); }
      });
      renderHistory();
    </script>

    <style is:global>
      :root {
        --bg: #f4f2ec;
        --surface: #fffefb;
        --ink: #1c1b19;
        --muted: #807b72;
        --faint: #a8a299;
        --line: #e4e0d6;
        --line-2: #d8d3c7;
        --accent: #2f6b54;
        --accent-soft: #e7efe9;
        --danger: #b1442f;
        --shadow: 0 1px 2px rgba(28,27,25,.04), 0 8px 24px rgba(28,27,25,.05);
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: 'Inter', system-ui, sans-serif;
        background: var(--bg);
        color: var(--ink);
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        line-height: 1.5;
      }

      .site {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.5rem clamp(1.2rem, 5vw, 3rem);
        max-width: 1080px; margin: 0 auto;
      }
      .wordmark {
        font-family: 'Newsreader', Georgia, serif;
        font-size: 1.4rem; font-weight: 600; letter-spacing: -.01em;
        color: var(--ink); text-decoration: none;
      }
      .meta-nav { display: flex; align-items: center; gap: .5rem; color: var(--muted); font-size: .82rem; }
      .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }

      .wrap { max-width: 1080px; margin: 0 auto; padding: clamp(1.2rem, 5vw, 2rem) clamp(1.2rem, 5vw, 3rem) 4rem; }

      .intro { max-width: 620px; margin: clamp(1rem, 4vw, 2.5rem) 0 2.2rem; }
      .intro h1 {
        font-family: 'Newsreader', Georgia, serif;
        font-weight: 500; font-size: clamp(2rem, 5vw, 2.9rem);
        line-height: 1.1; letter-spacing: -.02em; margin: 0 0 .6rem;
      }
      .intro p { margin: 0; color: var(--muted); font-size: 1.02rem; max-width: 30em; }

      .bar { display: flex; flex-wrap: wrap; gap: 1.6rem 2.4rem; margin-bottom: 1.4rem; }
      .field { display: flex; flex-direction: column; gap: .5rem; }
      .field-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .09em; color: var(--faint); font-weight: 500; }

      .seg { display: inline-flex; background: var(--surface); border: 1px solid var(--line-2); border-radius: 10px; padding: 3px; box-shadow: var(--shadow); }
      .seg-btn {
        border: 0; background: transparent; color: var(--muted); cursor: pointer;
        font: inherit; font-size: .88rem; font-weight: 500; padding: .4rem 1rem; border-radius: 7px;
        transition: color .15s, background .15s;
      }
      .seg-btn.active { background: var(--ink); color: var(--surface); }

      .pills { display: flex; flex-wrap: wrap; gap: .4rem; }
      .pill {
        border: 1px solid var(--line-2); background: var(--surface); color: var(--muted);
        cursor: pointer; font: inherit; font-size: .86rem; padding: .42rem .9rem; border-radius: 999px;
        transition: all .15s;
      }
      .pill:hover { border-color: var(--faint); color: var(--ink); }
      .pill.active { background: var(--accent-soft); border-color: var(--accent); color: var(--accent); font-weight: 500; }

      .editor { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
      @media (max-width: 740px) { .editor { grid-template-columns: 1fr; } }

      .pane {
        background: var(--surface); border: 1px solid var(--line); border-radius: 16px;
        display: flex; flex-direction: column; min-height: 340px; overflow: hidden; box-shadow: var(--shadow);
      }
      .pane-top {
        display: flex; align-items: center; justify-content: space-between;
        padding: .85rem 1.1rem; border-bottom: 1px solid var(--line);
      }
      .pane-title { font-size: .74rem; text-transform: uppercase; letter-spacing: .09em; color: var(--faint); font-weight: 500; }
      .count { font-size: .78rem; color: var(--faint); font-variant-numeric: tabular-nums; }

      textarea {
        flex: 1; resize: none; border: 0; background: transparent; color: var(--ink);
        padding: 1.2rem; font: inherit; font-size: 1.02rem; line-height: 1.7;
      }
      textarea::placeholder { color: var(--faint); }
      textarea:focus { outline: none; }

      .out { background: linear-gradient(180deg, #fffefb, #fdfcf8); }
      .output { flex: 1; padding: 1.2rem; overflow-y: auto; }
      .result {
        margin: 0; font-family: 'Newsreader', Georgia, serif; font-size: 1.18rem;
        line-height: 1.65; color: var(--ink); white-space: pre-wrap;
      }
      .ghost-text { margin: 0; color: var(--faint); font-family: 'Newsreader', Georgia, serif; font-size: 1.18rem; font-style: italic; }
      .err { margin: 0; color: var(--danger); }

      .actions { display: flex; align-items: center; justify-content: flex-end; gap: .8rem; margin-top: 1.2rem; }
      .reset {
        background: transparent; border: 0; color: var(--muted); cursor: pointer;
        font: inherit; font-size: .9rem; padding: .55rem .6rem;
      }
      .reset:hover { color: var(--ink); }
      .run {
        display: inline-flex; align-items: center; gap: .55rem;
        background: var(--ink); color: var(--surface); border: 0; border-radius: 11px;
        padding: .7rem 1.6rem; cursor: pointer; font: inherit; font-size: .95rem; font-weight: 500;
        transition: transform .12s, opacity .12s; box-shadow: var(--shadow);
      }
      .run:hover { transform: translateY(-1px); }
      .run:disabled { cursor: default; opacity: .85; transform: none; }
      .dots { display: inline-flex; gap: 3px; }
      .dots i { width: 4px; height: 4px; border-radius: 50%; background: currentColor; opacity: .4; animation: blink 1.2s infinite ease-in-out; }
      .dots i:nth-child(2) { animation-delay: .2s; }
      .dots i:nth-child(3) { animation-delay: .4s; }
      @keyframes blink { 0%, 80%, 100% { opacity: .25; } 40% { opacity: 1; } }

      .link-btn { background: transparent; border: 0; color: var(--accent); cursor: pointer; font: inherit; font-size: .82rem; font-weight: 500; padding: 0; }
      .link-btn:hover { text-decoration: underline; }
      .link-btn.subtle { color: var(--muted); }

      .recent { margin-top: 3rem; }
      .recent-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1rem; }
      .recent-head h2 { font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: 1.35rem; margin: 0; }
      .history { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: .9rem; }
      .rec {
        text-align: left; background: var(--surface); border: 1px solid var(--line); border-radius: 13px;
        padding: 1rem; cursor: pointer; font: inherit; color: var(--ink);
        transition: border-color .15s, transform .12s, box-shadow .15s;
      }
      .rec:hover { border-color: var(--line-2); transform: translateY(-2px); box-shadow: var(--shadow); }
      .rec-tags { display: flex; align-items: center; gap: .4rem; margin-bottom: .6rem; }
      .tag { font-size: .68rem; text-transform: uppercase; letter-spacing: .05em; background: var(--ink); color: var(--surface); border-radius: 5px; padding: .12rem .4rem; }
      .tag.soft { background: var(--accent-soft); color: var(--accent); }
      .rec-time { font-size: .72rem; color: var(--faint); margin-left: auto; }
      .rec-body {
        font-family: 'Newsreader', Georgia, serif; font-size: .98rem; line-height: 1.55; color: var(--muted);
        display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
      }

      .foot {
        display: flex; align-items: center; justify-content: center; gap: .6rem;
        color: var(--faint); font-size: .8rem; padding: 2.5rem 1rem;
        border-top: 1px solid var(--line); max-width: 1080px; margin: 2rem auto 0;
      }
      .foot .sep { opacity: .5; }
    </style>
  </body>
</html>
